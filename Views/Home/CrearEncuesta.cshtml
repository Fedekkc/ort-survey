@{
    ViewData["Title"] = "Crear Encuesta";
}

<h1>Nueva Encuesta</h1>

<form id="encuestaForm">
    <input id="titulo" placeholder="Titulo"><br>
    <input id="descripcion" placeholder="Descripcion"><br>
    <label>
        ES publica? :
        <input id="es_publica" type="checkbox">
    </label><br>
    <input id="estado" placeholder="Estado"><br>

    <h3>Preguntas</h3>
    <div id="preguntasContainer"></div>
    <button type="button" id="addPregunta">+ Pregunta</button><br><br>

    <button type="submit">Crear Encuesta</button>
</form>

<div id="resultado"></div>


@section Scripts {
    <script src="~/js/crearEncuesta.js"></script>
}